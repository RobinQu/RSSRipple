# Database
DATABASE_URL=sqlite+aiosqlite:///data/rss_ripple_dev.db

# LLM (OpenAI-compatible API)
# Default uses OpenRouter free model. Set LLM_API_KEY to your OpenRouter API key.
# Alternatives: google/gemini-2.0-flash-exp:free, meta-llama/llama-3-8b-instruct:free
LLM_API_KEY=
LLM_MODEL=openrouter/free
LLM_BASE_URL=https://openrouter.ai/api/v1

# Metadata providers (for TVSeries/Movie external ID matching)
# TMDB v3: https://www.themoviedb.org/settings/api
TMDB_API_KEY=
# Jina Search: https://jina.ai/api-dashboard/  (deprecated, replaced by Exa)
JINA_API_KEY=
# Exa AI Agent API: https://exa.ai/  (replaces Jina for web search fallback)
EXA_API_KEY=
EXA_EFFORT_LEVEL=low

# Scheduler
DEFAULT_FETCH_INTERVAL=1800

# Download
MAX_RETRY_COUNT=3
TASK_EXPIRE_DAYS=30

# App
LOG_LEVEL=INFO
DEBUG=false
