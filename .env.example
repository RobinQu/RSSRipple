# Database
DATABASE_URL=sqlite+aiosqlite:///data/rss_downloader.db

# LLM (OpenAI-compatible API)
# Default uses OpenRouter free model. Set LLM_API_KEY to your OpenRouter API key.
# Alternatives: google/gemini-2.0-flash-exp:free, meta-llama/llama-3-8b-instruct:free
LLM_API_KEY=
LLM_MODEL=openrouter/free
LLM_BASE_URL=https://openrouter.ai/api/v1

# Metadata providers (for TVSeries/Movie external ID matching)
# TMDB: https://www.themoviedb.org/settings/api
TMDB_API_KEY=
# TVDB: https://thetvdb.com/dashboard/account/apikey
TVDB_API_KEY=

# Scheduler
DEFAULT_FETCH_INTERVAL=1800

# Download
MAX_RETRY_COUNT=3
TASK_EXPIRE_DAYS=30

# App
LOG_LEVEL=INFO
DEBUG=false
