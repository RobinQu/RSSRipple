# Midscene AI model configuration
# Copy this file to tests/midscene/.env and fill in your API keys
# See: https://midscenejs.com/model-strategy.html

MIDSCENE_MODEL_BASE_URL="https://api.openai.com/v1"
MIDSCENE_MODEL_API_KEY="sk-your-api-key-here"
MIDSCENE_MODEL_NAME="gpt-4o"
MIDSCENE_MODEL_FAMILY="openai"

# RSSRipple app URL (Vite dev server default)
RSSRIPPLE_URL=http://localhost:5173
